    name = "util_objc",
    srcs = [
        "mac/launchd.h",
        "mac/launchd.mm",
        "misc/implicit_cast.h",
    ],
    visibility = [":__pkg__"],
    deps = [
        ":no_cfi_icall",
        "//compat",
        "@mini_chromium",
    ],
)

crashpad_cc_library(
    name = "util",
    srcs = _COMMON_SRCS + select({
        "//build:posix": _POSIX_SRCS,
        "//conditions:default": [],
    }) + select({
        "//build:linux": _LINUX_SRCS,
        "//build:macos": _MAC_SRCS,
        "//conditions:default": [],
    }),
    hdrs = _COMMON_HDRS + select({
        "//build:posix": _POSIX_HDRS,
        "//conditions:default": [],
    }) + select({
        "//build:linux": _LINUX_HDRS,
        "//build:macos": _MAC_HDRS,
        "//conditions:default": [],
    }),
    defines = ["ZLIB_CONST"],
    linkopts = select({
        "//build:macos": [
            "-framework CoreFoundation",
            "-framework Foundation",
            "-framework IOKit",
            "-lbsm",
        ],
        "//conditions:default": [],
    }),
    textual_hdrs = select({
        "//build:linux": ["misc/arm64_pac_bti.S"],
        "//conditions:default": [],
    }),
    deps = [
        ":no_cfi_icall",
        "//compat",
        "//third_party/zlib",
        "@mini_chromium",
    ] + select({
        "//build:linux": ["//third_party/lss"],
        "//build:macos": [
            ":mig_output",
            ":util_objc",
        ],
        "//conditions:default": [],
    }),
)

