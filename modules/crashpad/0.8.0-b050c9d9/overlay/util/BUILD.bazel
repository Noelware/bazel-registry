)

mig_library(
    name = "mig_output",
    srcs = select({
        "//build:macos": [
            "mach/child_port.defs",
            "//third_party/xnu:osfmk/mach/mach_exc.defs",
            "@mig_macos_sdk//:usr/include/mach/exc.defs",
            "@mig_macos_sdk//:usr/include/mach/notify.defs",
        ],
        "//conditions:default": [],
    }),
    defines = [
        "MACH_EXC_SERVER_TASKIDTOKEN",
        "MACH_EXC_SERVER_TASKIDTOKEN_STATE",
    ],
    includes = [
        "..",
        "../compat/mac",
    ],
    visibility = [":__pkg__"],
    deps = [
        ":child_port_types",
        "//:config",
    ],
)

