load("//build:cc.bzl", "crashpad_cc_binary", "crashpad_cc_library", "crashpad_cc_test", "crashpad_objc_library")

package(
    default_visibility = ["//visibility:public"],
)

crashpad_objc_library(
    name = "common_mac",
    srcs = [
        "crash_report_database.h",
        "crash_report_database_mac.mm",
        "settings.h",
    ],
    visibility = [":__pkg__"],
    deps = [
        "//util",
        "@mini_chromium",
    ],
)

crashpad_cc_library(
    name = "common",
    srcs = [
        "annotation.cc",
        "annotation_list.cc",
        "crash_report_database.cc",
        "crashpad_info.cc",
        "settings.cc",
    ] + select({
        "//build:linux": [
            "crash_report_database_generic.cc",
            "crashpad_info_note.S",
        ],
        "//conditions:default": [],
    }),
    hdrs = [
        "annotation.h",
        "annotation_list.h",
        "crash_report_database.h",
        "crashpad_info.h",
        "length_delimited_ring_buffer.h",
        "ring_buffer_annotation.h",
        "settings.h",
        "simple_address_range_bag.h",
        "simple_string_dictionary.h",
    ],
    deps = [
        "//util",
        "@mini_chromium",
    ] + select({
        "//build:macos": [":common_mac"],
        "//conditions:default": [],
    }),
)

crashpad_cc_library(
    name = "client",
    srcs = [
        "prune_crash_reports.cc",
    ] + select({
        "//build:linux": [
            "client_argv_handling.cc",
            "crashpad_client_linux.cc",
        ],
        "//build:macos": [
            "crashpad_client_mac.cc",
            "simulate_crash_mac.cc",
        ],
    }),
    hdrs = [
        "crashpad_client.h",
        "prune_crash_reports.h",
        "simulate_crash.h",
    ] + select({
        "//build:linux": [
            "client_argv_handling.h",
            "simulate_crash_linux.h",
        ],
        "//build:macos": [
            "simulate_crash_mac.h",
        ],
    }),
    deps = [
        ":common",
        "//util",
        "@mini_chromium",
    ] + select({
        "//build:linux": ["//third_party/lss"],
        "//conditions:default": [],
    }),
)

crashpad_cc_library(
    name = "pthread_create",
    srcs = ["pthread_create_linux.cc"],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [":client"],
)

crashpad_cc_binary(
    name = "ring_buffer_annotation_load_test",
    testonly = True,
    srcs = ["ring_buffer_annotation_load_test_main.cc"],
    deps = [
        ":client",
        "//tools:tool_support",
        "@mini_chromium",
    ],
)

crashpad_cc_test(
    name = "client_test",
    size = "small",
    srcs = [
        "annotation_list_test.cc",
        "annotation_test.cc",
        "crash_report_database_test.cc",
        "crashpad_info_test.cc",
        "length_delimited_ring_buffer_test.cc",
        "prune_crash_reports_test.cc",
        "ring_buffer_annotation_test.cc",
        "settings_test.cc",
        "simple_address_range_bag_test.cc",
        "simple_string_dictionary_test.cc",
    ] + select({
        "//build:linux": ["crashpad_client_linux_test.cc"],
        "//build:macos": ["simulate_crash_mac_test.cc"],
    }),
    data = ["//handler:crashpad_handler"],
    env = {
        "CRASHPAD_HANDLER_RLOCATION": "$(rlocationpath //handler:crashpad_handler)",
    },
    deps = [
        ":client",
        "//compat",
        "//snapshot",
        "//test",
        "//util",
        "@googletest//:gtest",
        "@mini_chromium",
        "@rules_cc//cc/runfiles",
    ],
)
